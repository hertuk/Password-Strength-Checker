using System;
using System.Text.RegularExpressions;

class Program
{
    static void Main()
    {
        string password = "Test1234";

        bool strong =
            password.Length >= 8 &&
            Regex.IsMatch(password, "[A-Z]") &&
            Regex.IsMatch(password, "[0-9]");

        Console.WriteLine(
            $"Password strength: {(strong ? "Strong" : "Weak")}"
        );
    }
}
